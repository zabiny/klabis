# Local-dev override — copy this file to .env.development.local (gitignored).
# Activates the klabis-web-local confidential client which receives a refresh_token,
# enabling silent token renewal when the frontend runs on http://localhost:3000
# (cross-origin from the backend on https://localhost:8443).
# The backend must be started with the local-dev Spring profile (runLocalEnvironment.sh does this automatically).
# See openspec/changes/enable-refresh-tokens-for-local-dev for full rationale.
VITE_OAUTH_CLIENT_ID=klabis-web-local
VITE_OAUTH_CLIENT_SECRET=local-dev-secret-please-change-nothing
VITE_OAUTH_SCOPE=openid profile MEMBERS EVENTS

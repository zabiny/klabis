###
# OpenID Connect Authentication Examples
#
# This file demonstrates the OpenID Connect (OIDC) authentication flow
# supported by the Klabis Authorization Server.
#
# Environment variables are defined in http-client.env.json:
# - {{apiBaseUrl}}: Base URL of the API (e.g., https://localhost:8443)
# - {{clientId}}: OAuth2 client ID
# - {{clientSecret}}: OAuth2 client secret
#
# Prerequisites:
# - Server must be running (./gradlew bootRun)
# - Bootstrap data loaded (admin user and OAuth2 client)
#
# Authentication Flow:
# 1. Discovery: Get OIDC configuration metadata
# 2. Authorize: Get authorization code (browser-based, manual step)
# 3. Token: Exchange code for access_token + id_token
# 4. UserInfo: Get user profile data using access_token
###

### 1. OIDC Discovery Endpoint
# Returns OpenID Connect discovery metadata
# This endpoint provides all OIDC endpoint URLs and supported features
GET {{baseUrl}}/.well-known/openid-configuration

###

### 2. JWKS Endpoint (JSON Web Key Set)
# Returns public keys used to verify JWT signatures
GET {{baseUrl}}/oauth2/jwks

###

### 3. Authorization Endpoint (Manual Step - Use Browser)
# This step requires browser interaction for user login
# Copy this URL and open it in a browser:
#
# {{baseUrl}}/oauth2/authorize?response_type=code&client_id={{clientId}}&scope=openid%20profile%20email%20MEMBERS:READ&redirect_uri={{redirectUri}}&state=random-state-123
#
# Note: Including 'profile' and 'email' scopes enables UserInfo endpoint to return user profile claims
# After login (username: admin, password: admin123), you'll be redirected to:
# {{redirectUri}}?code=AUTHORIZATION_CODE&state=random-state-123
#
# Copy the AUTHORIZATION_CODE from the redirect URL and use it in the next request.

###

### 4. Token Endpoint - Exchange Authorization Code for Tokens
# Exchange the authorization code for access_token, id_token, and refresh_token
# Replace AUTHORIZATION_CODE with the code from step 3
POST {{baseUrl}}/oauth2/token
Content-Type: application/x-www-form-urlencoded

grant_type = authorization_code
    &
code = AUTHORIZATION_CODE
    &
redirect_uri = {{redirectUri}}
    &
client_id = {{clientId}} &
client_secret = {{clientSecret}}

> {%
    // Save tokens for subsequent requests
    client.global.set("access_token", response.body.access_token);
    client.global.set("id_token", response.body.id_token);
    client.global.set("refresh_token", response.body.refresh_token);

    // Decode and display ID token payload (for debugging)
    const idToken = response.body.id_token;
    const payload = idToken.split('.')[1];
    const decoded = JSON.parse(atob(payload));
    console.log("ID Token Claims:");
    console.log(JSON.stringify(decoded, null, 2));
%}

###

### 5. UserInfo Endpoint - Get User Profile Data
# Requires valid access_token with 'openid' scope
# Scope-based claims:
#   - openid scope: returns only 'sub' claim
#   - profile scope: adds 'given_name', 'family_name', 'registrationNumber', 'updated_at' (requires Member entity)
#   - email scope: adds 'email', 'email_verified' (requires Member entity with email)
# Example response with openid+profile+email scopes:
# {
#   "sub": "ZBM0501",
#   "given_name": "Jan",
#   "family_name": "Novák",
#   "registrationNumber": "ZBM0501",
#   "updated_at": "2026-02-09T12:00:00Z",
#   "email": "jan.novak@example.com",
#   "email_verified": false
# }
GET {{baseUrl}}/userinfo
Authorization: Bearer {{access_token}}

###

### 6. Introspect Access Token (Optional)
# Check token validity and metadata
POST {{baseUrl}}/oauth2/introspect
Content-Type: application/x-www-form-urlencoded

token = {{access_token}}
    &
client_id = {{clientId}}
    &
client_secret = {{clientSecret}}

###

### 7. Refresh Token - Get New Access Token
# Use refresh_token to obtain a new access_token without re-authentication
POST {{baseUrl}}/oauth2/token
Content-Type: application/x-www-form-urlencoded

grant_type = refresh_token
    &
refresh_token = {{refresh_token}}
    &
client_id = {{clientId}}
    &
client_secret = {{clientSecret}}

> {%
    // Update access_token after refresh
    client.global.set("access_token", response.body.access_token);
    if (response.body.refresh_token) {
        client.global.set("refresh_token", response.body.refresh_token);
    }
%}

###

### 8. Revoke Token (Logout)
# Revoke the refresh_token to invalidate the session
POST {{baseUrl}}/oauth2/revoke
Content-Type: application/x-www-form-urlencoded

token = {{refresh_token}}
    &
token_type_hint = refresh_token
    &
client_id = {{clientId}}
    &
client_secret = {{clientSecret}}

###

### 9. Use Access Token to Call Protected API
# Example: Get members list using the access_token
GET {{apiBaseUrl}}/members
Authorization: Bearer {{access_token}}

###

### Alternative: Client Credentials Flow (No OpenID, No User Context)
# For machine-to-machine authentication without user login
# This flow does NOT return an id_token (no openid scope support)
POST {{baseUrl}}/oauth2/token
Content-Type: application/x-www-form-urlencoded

grant_type = client_credentials
    &
scope = MEMBERS:READ
    &
client_id = {{clientId}}
    &
client_secret = {{clientSecret}}

> {%
    client.global.set("client_credentials_token", response.body.access_token);
%}

###

### Use Client Credentials Token
GET {{apiBaseUrl}}/members
Authorization: Bearer {{client_credentials_token}}

###

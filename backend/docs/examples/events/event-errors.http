### Scenario 4: Business Logic Violations (Illegal State)

### 4.1 Try to publish already published event
# First, create and publish an event
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "Double Publish Test",
  "eventDate": "2026-10-01",
  "location": "Test",
  "organizer": "OOB"
}

> {%
    client.global.set('doublePublishEventId', response.body.id);
%}

###

POST {{apiBaseUrl}}/events/{{doublePublishEventId}}/publish
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

> {%
    client.test("First publish succeeds", function () {
        client.assert(response.status === 200);
    });
%}

###

POST {{apiBaseUrl}}/events/{{doublePublishEventId}}/publish
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

> {%
    client.test("Second publish fails", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
        client.assert(response.body.detail !== undefined, "Should explain error");
    });
%}

###

### 4.2 Try to cancel already cancelled event
POST {{apiBaseUrl}}/events/{{doublePublishEventId}}/cancel
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

> {%
    client.test("First cancel succeeds", function () {
        client.assert(response.status === 200);
    });
%}

###

POST {{apiBaseUrl}}/events/{{doublePublishEventId}}/cancel
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

> {%
    client.test("Second cancel fails", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
    });
%}

###

### 4.3 Try to update FINISHED event
POST {{apiBaseUrl}}/events/{{doublePublishEventId}}/finish
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

###

PATCH {{apiBaseUrl}}/events/{{doublePublishEventId}}
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "Should not update finished event"
}

> {%
    client.test("Cannot update FINISHED event", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
    });
%}

###

### 4.4 Try to update CANCELLED event
# Already cancelled above, try to update
PATCH {{apiBaseUrl}}/events/{{doublePublishEventId}}
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "Should not update cancelled event"
}

> {%
    client.test("Cannot update CANCELLED event", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
    });
%}

###

### Scenario 5: Registration Errors

### 5.1 Register for non-ACTIVE event (DRAFT)
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "Draft Registration Error Test",
  "eventDate": "2026-11-01",
  "location": "Test",
  "organizer": "PRG"
}

> {%
    client.global.set('draftRegEventId', response.body.id);
%}

###

POST {{apiBaseUrl}}/events/{{draftRegEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "111222"
}

> {%
    client.test("Cannot register for DRAFT event", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
        client.assert(response.body.detail.includes("ACTIVE"), "Error should mention ACTIVE status");
    });
%}

###

### 5.2 Register with invalid SI card number
POST {{apiBaseUrl}}/events/{{doublePublishEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "ABC"
}

> {%
    client.test("Invalid SI card rejected", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
    });
%}

###

### 5.3 Try to unregister when not registered
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "Unregister Error Test",
  "eventDate": "2026-12-01",
  "location": "Test",
  "organizer": "BRN"
}

> {%
    client.global.set('unregisterErrorEventId', response.body.id);
%}

###

POST {{apiBaseUrl}}/events/{{unregisterErrorEventId}}/publish
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

###

DELETE {{apiBaseUrl}}/events/{{unregisterErrorEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}

> {%
    client.test("Unregister when not registered returns 404", function () {
        client.assert(response.status === 404, "Expected 404 Not Found");
    });
%}

###

### Scenario 6: Pagination and Filtering Errors

### 6.1 Invalid page number (negative)
GET {{apiBaseUrl}}/events?page=-1
Authorization: Bearer {{$auth.token("EventsManagement")}}
Accept: {{halContentType}}

> {%
    client.test("Negative page number handled", function () {
        client.assert(response.status === 400 || response.status === 200, "May validate or default to 0");
    });
%}

###

### 6.2 Invalid page size (too large)
GET {{apiBaseUrl}}/events?size=1000
Authorization: Bearer {{$auth.token("EventsManagement")}}
Accept: {{halContentType}}

> {%
    client.test("Large page size handled", function () {
        client.assert(response.status === 200, "Should cap to max size");
    });
%}

###

### 6.3 Invalid date format in filter
GET {{apiBaseUrl}}/events?eventDateFrom=invalid-date
Authorization: Bearer {{$auth.token("EventsManagement")}}
Accept: {{halContentType}}

> {%
    client.test("Invalid date format in filter returns 400", function () {
        client.assert(response.status === 400);
    });
%}

###

### Scenario 3: Not Found Errors

### 3.1 Get non-existent event
GET {{apiBaseUrl}}/events/00000000-0000-0000-0000-000000000001
Authorization: Bearer {{$auth.token("EventsManagement")}}
Accept: {{halContentType}}

> {%
    client.test("Non-existent event returns 404", function () {
        client.assert(response.status === 404, "Expected 404 Not Found");
        client.assert(response.body.title === "Event Not Found", "Should have proper error title");
    });
%}

###

### 3.2 Update non-existent event
PATCH {{apiBaseUrl}}/events/00000000-0000-0000-0000-000000000002
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "Should not update"
}

> {%
    client.test("Update non-existent event returns 404", function () {
        client.assert(response.status === 404);
    });
%}

###


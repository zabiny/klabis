### event-errors.http
###
### Event API Error Scenarios
### Tests for error handling and edge cases
###
### Usage: Use with IntelliJ HTTP Client or similar tools
### Requires: Variable `apiBaseUrl` defined in http-client.env.json
###

### Scenario 1: Authentication and Authorization Errors

### 1.1 Try to access event management without authentication
GET {{apiBaseUrl}}/events
Accept: {{halContentType}}

> {%
    client.test("Unauthorized request returns 401", function () {
        client.assert(response.status === 401, "Expected 401 Unauthorized");
    });
%}

###

### 1.2 Try to create event without EVENTS:MANAGE authority
# Note: This test requires a token without EVENTS:MANAGE scope
# Adjust the token config to use a token with limited scope
GET {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Accept: {{halContentType}}

> {%
    client.test("Request with limited scope works for GET", function () {
        client.assert(response.status === 200 || response.status === 403, "May succeed or return 403");
    });
%}

###

### 1.3 Try to create event without proper authority
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "name": "Unauthorized Event",
  "eventDate": "2026-08-01",
  "location": "Test",
  "organizer": "OOB",
  "websiteUrl": null,
  "eventCoordinatorId": null
}

> {%
    client.test("Create without EVENTS:MANAGE returns 403", function () {
        client.assert(response.status === 403, "Expected 403 Forbidden");
    });
%}

###

### Scenario 2: Validation Errors

### 2.1 Create event with missing required fields
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "",
  "eventDate": "invalid",
  "location": "",
  "organizer": "INVALIDLONGCODE"
}

> {%
    client.test("Invalid data returns 400", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
        client.assert(response.body.detail !== undefined, "Should have error details");
    });
%}

###

### 2.2 Create event with blank name
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "   ",
  "eventDate": "2026-09-01",
  "location": "Test",
  "organizer": "OOB"
}

> {%
    client.test("Blank name rejected", function () {
        client.assert(response.status === 400);
    });
%}

###

### 2.3 Create event with invalid date format
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "Invalid Date Test",
  "eventDate": "not-a-date",
  "location": "Test",
  "organizer": "OOB"
}

> {%
    client.test("Invalid date format rejected", function () {
        client.assert(response.status === 400);
    });
%}

###

### 2.4 Create event with organizer code too long
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "Invalid Organizer Test",
  "eventDate": "2026-09-01",
  "location": "Test",
  "organizer": "VERYLONGORG"
}

> {%
    client.test("Organizer code too long rejected", function () {
        client.assert(response.status === 400);
    });
%}

###

### 2.5 Create event with invalid website URL
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "Invalid URL Test",
  "eventDate": "2026-09-01",
  "location": "Test",
  "organizer": "OOB",
  "websiteUrl": "not-a-valid-url"
}

> {%
    client.test("Invalid URL rejected", function () {
        client.assert(response.status === 400);
    });
%}


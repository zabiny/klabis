### event-management.http
###
### Event Management API scenarios
### Tests for creating, reading, updating, and managing event lifecycle
###
### Usage: Use with IntelliJ HTTP Client or similar tools
### Requires: Variable `apiBaseUrl` defined in http-client.env.json
### Requires: OAuth2 token with EVENTS:MANAGE authority
###

### Scenario 1: Complete event lifecycle (create → publish → finish)

### 1.1 Create event (DRAFT status)
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Content-Type: application/json

{
  "name": "Spring Cup 2026",
  "eventDate": "2026-03-15",
  "location": "Forest Park",
  "organizer": "OOB",
  "websiteUrl": "https://observer.cz/zavody/spring-cup-2026",
  "eventCoordinatorId": null
}

> {%
    client.test("Event created successfully", function () {
        client.assert(response.status === 201, "Expected 201 Created");
        client.assert(response.body.id !== undefined, "Event ID should be returned");
        client.assert(response.body.status === "DRAFT", "Initial status should be DRAFT");
        client.assert(response.body._links !== undefined, "HATEOAS links should be present");
    });
    client.global.set('eventId', response.body.id);
    client.global.set('eventName', response.body.name);
%}

###

### 1.2 Get event details (DRAFT)
GET {{apiBaseUrl}}/events/{{eventId}}
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Accept: {{halContentType}}

> {%
    client.test("DRAFT event retrieved", function () {
        client.assert(response.status === 200);
        client.assert(response.body.id === client.global.get('eventId'));
        client.assert(response.body.status === "DRAFT");
        // DRAFT events should have: self, collection, edit, publish, cancel, registrations
        const links = response.body._links;
        client.assert(links.self !== undefined, "Should have self link");
        client.assert(links.edit !== undefined, "DRAFT should have edit link");
        client.assert(links.publish !== undefined, "DRAFT should have publish link");
        client.assert(links.cancel !== undefined, "DRAFT should have cancel link");
        client.assert(links.registrations !== undefined, "Should have registrations link");
    });
%}

###

### 1.3 Publish event (DRAFT → ACTIVE)
POST {{apiBaseUrl}}/events/{{eventId}}/publish
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Content-Type: application/json

> {%
    client.test("Event published successfully", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        client.assert(response.body.status === "ACTIVE", "Status should be ACTIVE");
    });
%}

###

### 1.4 Get event details (ACTIVE)
GET {{apiBaseUrl}}/events/{{eventId}}
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Accept: {{halContentType}}

> {%
    client.test("ACTIVE event retrieved", function () {
        client.assert(response.status === 200);
        client.assert(response.body.status === "ACTIVE");
        // ACTIVE events should have: self, collection, edit, cancel, finish, registrations
        const links = response.body._links;
        client.assert(links.self !== undefined, "Should have self link");
        client.assert(links.edit !== undefined, "ACTIVE should have edit link");
        client.assert(links.cancel !== undefined, "ACTIVE should have cancel link");
        client.assert(links.finish !== undefined, "ACTIVE should have finish link");
        client.assert(links.publish === undefined, "ACTIVE should NOT have publish link");
    });
%}

###

### 1.5 Finish event (ACTIVE → FINISHED)
POST {{apiBaseUrl}}/events/{{eventId}}/finish
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Content-Type: application/json

> {%
    client.test("Event finished successfully", function () {
        client.assert(response.status === 200);
        client.assert(response.body.status === "FINISHED", "Status should be FINISHED");
    });
%}

###

### 1.6 Get event details (FINISHED)
GET {{apiBaseUrl}}/events/{{eventId}}
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Accept: {{halContentType}}

> {%
    client.test("FINISHED event retrieved", function () {
        client.assert(response.status === 200);
        client.assert(response.body.status === "FINISHED");
        // FINISHED events are read-only: self, collection, registrations only
        const links = response.body._links;
        client.assert(links.self !== undefined, "Should have self link");
        client.assert(links.edit === undefined, "FINISHED should NOT have edit link");
        client.assert(links.publish === undefined, "FINISHED should NOT have publish link");
        client.assert(links.cancel === undefined, "FINISHED should NOT have cancel link");
        client.assert(links.finish === undefined, "FINISHED should NOT have finish link");
    });
%}

###

### Scenario 2: Event lifecycle with cancellation

### 2.1 Create another event for cancellation test
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Content-Type: application/json

{
  "name": "Cancelled Event Test",
  "eventDate": "2026-04-20",
  "location": "Test Location",
  "organizer": "PRG",
  "websiteUrl": null,
  "eventCoordinatorId": null
}

> {%
    client.global.set('cancelEventId', response.body.id);
%}

###

### 2.2 Publish event
POST {{apiBaseUrl}}/events/{{cancelEventId}}/publish
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Content-Type: application/json

###

### 2.3 Cancel event (ACTIVE → CANCELLED)
POST {{apiBaseUrl}}/events/{{cancelEventId}}/cancel
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Content-Type: application/json

> {%
    client.test("Event cancelled successfully", function () {
        client.assert(response.status === 200);
        client.assert(response.body.status === "CANCELLED", "Status should be CANCELLED");
    });
%}

###

### 2.4 Verify cancelled event is read-only
GET {{apiBaseUrl}}/events/{{cancelEventId}}
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Accept: {{halContentType}}

> {%
    client.test("CANCELLED event is read-only", function () {
        client.assert(response.status === 200);
        client.assert(response.body.status === "CANCELLED");
        // CANCELLED events are read-only
        const links = response.body._links;
        client.assert(links.self !== undefined, "Should have self link");
        client.assert(links.edit === undefined, "CANCELLED should NOT have edit link");
        client.assert(links.publish === undefined, "CANCELLED should NOT have publish link");
        client.assert(links.cancel === undefined, "CANCELLED should NOT have cancel link again");
        client.assert(links.finish === undefined, "CANCELLED should NOT have finish link");
    });
%}

###

### Scenario 3: Event CRUD operations

### 3.1 Create event with all fields
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Content-Type: application/json

{
  "name": "Summer Championship 2026",
  "eventDate": "2026-07-10",
  "location": "Mountain Resort",
  "organizer": "BRN",
  "websiteUrl": "https://orienteering.cz/summer-2026",
  "eventCoordinatorId": null
}

> {%
    client.global.set('crudEventId', response.body.id);
%}

###

### 3.2 Update event (DRAFT)
PATCH {{apiBaseUrl}}/events/{{crudEventId}}
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Content-Type: application/json

{
  "name": "Summer Championship 2026 (Updated)",
  "location": "Alpine Resort",
  "websiteUrl": "https://orienteering.cz/summer-2026-updated"
}

> {%
    client.test("Event updated successfully", function () {
        client.assert(response.status === 200);
        client.assert(response.body.name.includes("Updated"), "Name should be updated");
        client.assert(response.body.location === "Alpine Resort", "Location should be updated");
    });
%}

###

### 3.3 Delete not allowed - use cancel instead
# Note: Events are soft-deleted via CANCELLED status
# There is no DELETE endpoint - use cancel instead

###

### Scenario 4: List events with pagination and filtering

### 4.1 List all events (default pagination)
GET {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Accept: {{halContentType}}

> {%
    client.test("Events list retrieved", function () {
        client.assert(response.status === 200);
        client.assert(response.body._embedded.eventSummaryDtoList !== undefined, "Should have events list");
        client.assert(Array.isArray(response.body._embedded.eventSummaryDtoList), "Should be array");
        client.assert(response.body.page !== undefined, "Should have pagination metadata");
    });
%}

###

### 4.2 List only ACTIVE events
GET {{apiBaseUrl}}/events?status=ACTIVE
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Accept: {{halContentType}}

> {%
    client.test("Only ACTIVE events returned", function () {
        client.assert(response.status === 200);
        const events = response.body._embedded.eventSummaryDtoList;
        if (events.length > 0) {
            events.forEach(function (event) {
                client.assert(event.status === "ACTIVE", "All events should be ACTIVE");
            });
        }
    });
%}

###

### 4.3 List events with pagination
GET {{apiBaseUrl}}/events?page=0&size=5
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Accept: {{halContentType}}

> {%
    client.test("Pagination works", function () {
        client.assert(response.status === 200);
        const page = response.body.page;
        client.assert(page.size === 5, "Page size should be 5");
        client.assert(page.number === 0, "Page number should be 0");
    });
%}

###

### 4.4 Filter by organizer
GET {{apiBaseUrl}}/events?organizer=OOB
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Accept: {{halContentType}}

> {%
    client.test("Filter by organizer works", function () {
        client.assert(response.status === 200);
        const events = response.body._embedded.eventSummaryDtoList;
        if (events.length > 0) {
            events.forEach(function (event) {
                client.assert(event.organizer === "OOB", "All events should be OOB");
            });
        }
    });
%}

###

### 4.5 Filter by date range
GET {{apiBaseUrl}}/events?eventDateFrom=2026-01-01&eventDateTo=2026-12-31
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Accept: {{halContentType}}

> {%
    client.test("Filter by date range works", function () {
        client.assert(response.status === 200);
        // Date range filtering should work
    });
%}

###

### Scenario 5: Error handling

### 5.1 Try to update FINISHED event (should fail)
PATCH {{apiBaseUrl}}/events/{{eventId}}
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Content-Type: application/json

{
  "name": "Should not update"
}

> {%
    client.test("Cannot update FINISHED event", function () {
        client.assert(response.status === 400, "Should return 400 Bad Request");
    });
%}

###

### 5.2 Try to publish FINISHED event (should fail)
POST {{apiBaseUrl}}/events/{{eventId}}/publish
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Content-Type: application/json

> {%
    client.test("Cannot publish FINISHED event", function () {
        client.assert(response.status === 400, "Should return 400 Bad Request");
    });
%}

###

### 5.3 Get non-existent event (404)
GET {{apiBaseUrl}}/events/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Accept: {{halContentType}}

> {%
    client.test("Non-existent event returns 404", function () {
        client.assert(response.status === 404, "Should return 404 Not Found");
    });
%}

###

### 5.4 Try to create event with invalid data
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("AuthorizationCode")}}
Content-Type: application/json

{
  "name": "",
  "eventDate": "invalid-date",
  "location": "Test",
  "organizer": "INVALID"
}

> {%
    client.test("Invalid data returns 400", function () {
        client.assert(response.status === 400, "Should return 400 Bad Request");
    });
%}


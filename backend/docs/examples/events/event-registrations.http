### event-registrations.http
###
### Event Registration API scenarios
### Tests for member registration, listing, and unregistration from events
###
### Usage: Use with IntelliJ HTTP Client or similar tools
### Requires: Variable `apiBaseUrl` defined in http-client.env.json
### Requires: OAuth2 token (Authorization Code for member registration)
###

### Scenario 1: Complete registration flow

### 1.1 Setup: Create an ACTIVE event for registration testing
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "Registration Test Event",
  "eventDate": "2026-05-20",
  "location": "Test Forest",
  "organizer": "OOB",
  "websiteUrl": null,
  "eventCoordinatorId": null
}

> {%
    client.test("Event created for registration tests", function () {
        client.assert(response.status === 201);
    });
    client.global.set('registrationEventId', response.body.id);
%}

###

### 1.2 Publish the event to ACTIVE
POST {{apiBaseUrl}}/events/{{registrationEventId}}/publish
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

> {%
    client.test("Event published to ACTIVE", function () {
        client.assert(response.status === 200);
        client.assert(response.body.status === "ACTIVE");
    });
%}

###

### 1.3 Register for the event (authenticated member)
POST {{apiBaseUrl}}/events/{{registrationEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "123456"
}

> {%
    client.test("Registration successful", function () {
        client.assert(response.status === 201, "Expected 201 Created");
        client.assert(response.body.firstName !== undefined, "Should have firstName");
        client.assert(response.body.lastName !== undefined, "Should have lastName");
        client.assert(response.body.siCardNumber === "123456", "SI card should match");
        client.assert(response.body.registeredAt !== undefined, "Should have timestamp");
        client.assert(response.body._links !== undefined, "Should have HATEOAS links");
    });
%}

###

### 1.4 View own registration (includes SI card)
GET {{apiBaseUrl}}/events/{{registrationEventId}}/registrations/me
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Accept: {{halContentType}}

> {%
    client.test("Own registration retrieved with SI card", function () {
        client.assert(response.status === 200);
        client.assert(response.body.siCardNumber !== undefined, "Should include SI card");
        client.assert(response.body.firstName !== undefined, "Should have firstName");
        client.assert(response.body.lastName !== undefined, "Should have lastName");
        client.assert(response.body.registeredAt !== undefined, "Should have timestamp");
    });
%}

###

### 1.5 List all registrations (SI card hidden - privacy)
GET {{apiBaseUrl}}/events/{{registrationEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Accept: {{halContentType}}

> {%
    client.test("Registrations list hides SI cards", function () {
        client.assert(response.status === 200);
        const registrations = response.body._embedded.registrationDtoList;
        client.assert(Array.isArray(registrations), "Should be array");
        if (registrations.length > 0) {
            const first = registrations[0];
            client.assert(first.firstName !== undefined, "Should have firstName");
            client.assert(first.lastName !== undefined, "Should have lastName");
            client.assert(first.siCardNumber === undefined, "Should NOT have SI card (privacy)");
            client.assert(first.registeredAt !== undefined, "Should have timestamp");
        }
    });
%}

###

### 1.6 Unregister from event (before event date)
DELETE {{apiBaseUrl}}/events/{{registrationEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}

> {%
    client.test("Unregistration successful", function () {
        client.assert(response.status === 204, "Expected 204 No Content");
    });
%}

###

### 1.7 Verify registration is removed
GET {{apiBaseUrl}}/events/{{registrationEventId}}/registrations/me
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Accept: {{halContentType}}

> {%
    client.test("Registration removed", function () {
        client.assert(response.status === 404, "Should return 404 after unregistration");
    });
%}

###

### Scenario 2: Duplicate registration prevention

### 2.1 Register again
POST {{apiBaseUrl}}/events/{{registrationEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "789012"
}

> {%
    client.test("First registration successful", function () {
        client.assert(response.status === 201);
    });
%}

###

### 2.2 Try to register again with same SI card (should fail)
POST {{apiBaseUrl}}/events/{{registrationEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "789012"
}

> {%
    client.test("Duplicate registration prevented", function () {
        client.assert(response.status === 409, "Expected 409 Conflict");
    });
%}

###

### 2.3 Try to register with different SI card (should also fail - duplicate member, not SI card)
POST {{apiBaseUrl}}/events/{{registrationEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "999888"
}

> {%
    client.test("Duplicate member registration prevented", function () {
        client.assert(response.status === 409, "Expected 409 Conflict - member already registered");
    });
%}

###

### Scenario 3: Registration for non-ACTIVE events

### 3.1 Create DRAFT event
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "Draft Registration Test",
  "eventDate": "2026-06-15",
  "location": "Test",
  "organizer": "PRG",
  "websiteUrl": null,
  "eventCoordinatorId": null
}

> {%
    client.global.set('draftEventId', response.body.id);
%}

###

### 3.2 Try to register for DRAFT event (should fail)
POST {{apiBaseUrl}}/events/{{draftEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "111222"
}

> {%
    client.test("Cannot register for DRAFT event", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
    });
%}

###

### 3.3 Publish event to ACTIVE
POST {{apiBaseUrl}}/events/{{draftEventId}}/publish
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

###

### 3.4 Finish event
POST {{apiBaseUrl}}/events/{{draftEventId}}/finish
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

###

### 3.5 Try to register for FINISHED event (should fail)
POST {{apiBaseUrl}}/events/{{draftEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "111222"
}

> {%
    client.test("Cannot register for FINISHED event", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
    });
%}

###

### Scenario 4: Unregistration constraints

### 4.1 Create event in the past
POST {{apiBaseUrl}}/events
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

{
  "name": "Past Event Test",
  "eventDate": "2020-01-01",
  "location": "Test",
  "organizer": "BRN",
  "websiteUrl": null,
  "eventCoordinatorId": null
}

> {%
    client.global.set('pastEventId', response.body.id);
%}

###

### 4.2 Publish to ACTIVE
POST {{apiBaseUrl}}/events/{{pastEventId}}/publish
Authorization: Bearer {{$auth.token("EventsManagement")}}
Content-Type: application/json

###

### 4.3 Register for past event
POST {{apiBaseUrl}}/events/{{pastEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "333444"
}

> {%
    client.test("Registration for past event allowed", function () {
        client.assert(response.status === 201);
    });
%}

###

### 4.4 Try to unregister from past event (should fail - on or after event date)
DELETE {{apiBaseUrl}}/events/{{pastEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}

> {%
    client.test("Cannot unregister after event date", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
    });
%}

###

### Scenario 5: SI card number validation

### 5.1 Valid 4-digit SI card
POST {{apiBaseUrl}}/events/{{registrationEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "1234"
}

> {%
    client.test("Valid 4-digit SI card accepted", function () {
        client.assert(response.status === 201 || response.status === 409);
    });
%}

###

### 5.2 Valid 8-digit SI card
POST {{apiBaseUrl}}/events/{{registrationEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "12345678"
}

> {%
    client.test("Valid 8-digit SI card accepted", function () {
        client.assert(response.status === 201 || response.status === 409);
    });
%}

###

### 5.3 Invalid SI card with letters (should fail)
POST {{apiBaseUrl}}/events/{{registrationEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "ABC123"
}

> {%
    client.test("SI card with letters rejected", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
    });
%}

###

### 5.4 Invalid SI card too short (should fail)
POST {{apiBaseUrl}}/events/{{registrationEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "123"
}

> {%
    client.test("SI card too short rejected", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
    });
%}

###

### 5.5 Invalid SI card too long (should fail)
POST {{apiBaseUrl}}/events/{{registrationEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": "123456789"
}

> {%
    client.test("SI card too long rejected", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
    });
%}

###

### 5.6 Blank SI card (should fail)
POST {{apiBaseUrl}}/events/{{registrationEventId}}/registrations
Authorization: Bearer {{$auth.token("EventsRegistration")}}
Content-Type: application/json

{
  "siCardNumber": ""
}

> {%
    client.test("Blank SI card rejected", function () {
        client.assert(response.status === 400, "Expected 400 Bad Request");
    });
%}


# Klabis Backend - Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ==============================================================================
# REQUIRED VARIABLES
# ==============================================================================

# Jasypt Encryption (REQUIRED for GDPR-sensitive fields)
# Generate a strong password (min 32 characters recommended)
JASYPT_ENCRYPTOR_PASSWORD=change_this_to_a_very_long_random_secret_key_min_32_chars

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# PostgreSQL Database (used in production profile)
DB_USERNAME=klabis
DB_PASSWORD=change_this_password

# Connection Pool Settings (optional - defaults are usually fine)
# DB_POOL_MAX_SIZE=20
# DB_POOL_MIN_IDLE=10
# DB_CONNECTION_TIMEOUT=30000
# DB_IDLE_TIMEOUT=300000
# DB_MAX_LIFETIME=1800000

# ==============================================================================
# SMTP EMAIL CONFIGURATION
# ==============================================================================

# Email Server Settings (required for sending emails)
# Choose your provider from the options below:

# Gmail (requires App Passwords for 2FA accounts)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password

# Outlook/Office 365
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@outlook.com
# SMTP_PASSWORD=your-password

# SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# Amazon SES
# SMTP_HOST=email-smtp.${AWS_REGION}.amazonaws.com
# SMTP_PORT=587
# SMTP_USERNAME=your-smtp-username
# SMTP_PASSWORD=your-smtp-password

# Generic SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user
SMTP_PASSWORD=your-smtp-password

# ==============================================================================
# OAUTH2 & SECURITY
# ==============================================================================

# OAuth2 Authorization Server
OAUTH2_ISSUER=https://localhost:8443

# Bootstrap Admin User Credentials
# If not set, random passwords will be generated (check logs)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
# BOOTSTRAP_ADMIN_ID=  # Optional: specific UUID for admin user

# OAuth2 Client Registration
# If not set, random client secret will be generated (check logs)
OAUTH2_CLIENT_ID=klabis-web
OAUTH2_CLIENT_SECRET=secret
# OAUTH2_CLIENT_ID_UUID=  # Optional: specific UUID for OAuth2 client
# OAUTH2_CLIENT_REDIRECT_URIS=https://localhost:3000/callback,https://localhost:8443/callback.html
# OAUTH2_CLIENT_POST_LOGOUT_REDIRECT_URIS=https://wiki.zabiny.club
# OAUTH2_CLIENT_SCOPES=MEMBERS:CREATE,MEMBERS:READ,MEMBERS:UPDATE,MEMBERS:DELETE

# ==============================================================================
# FRONTEND CORS
# ==============================================================================

# Frontend Origin (for CORS)
FRONTEND_ALLOWED_ORIGINS=https://localhost:3000,https://localhost:8443
FRONTEND_ALLOW_CREDENTIALS=true

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================

# Club Code (used for generating registration numbers like ZBM0001)
CLUB_CODE=ZBM

# ==============================================================================
# NOTES
# ==============================================================================
#
# 1. SECURITY WARNING:
#    - Never commit .env files to version control
#    - Use strong, unique passwords for production
#    - Rotate credentials regularly
#
# 2. DEVELOPMENT:
#    - The 'dev' profile uses H2 in-memory database (no DB setup needed)
#    - Start with: mvn spring-boot:run
#
# 3. PRODUCTION:
#    - Set all credentials explicitly (don't rely on defaults)
#    - Use the 'prod' profile: mvn spring-boot:run -Dspring-boot.run.profiles=prod
#    - Ensure PostgreSQL is running and accessible
#
# 4. BOOTSTRAP CREDENTIALS:
#    - If BOOTSTRAP_ADMIN_PASSWORD or OAUTH2_CLIENT_SECRET are not set,
#      random passwords will be generated and logged at startup
#    - Save these generated passwords for future use!
#
# 5. JASYPT ENCRYPTION:
#    - Keep the encryption password backed up securely
#    - If lost, encrypted data (emails, phone numbers) cannot be decrypted
#    - Use a password manager or secrets management service

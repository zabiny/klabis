# Klabis Backend - Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
#
# All environment variables use KLABIS_ prefix for clear namespacing.

# ==============================================================================
# REQUIRED VARIABLES
# ==============================================================================

# Jasypt Encryption (REQUIRED for GDPR-sensitive fields)
KLABIS_JASYPT_PASSWORD=change_this_to_a_very_long_random_secret_key_min_32_chars

# ==============================================================================
# DATABASE CONFIGURATION (production profile only)
# ==============================================================================

KLABIS_DB_USERNAME=klabis
KLABIS_DB_PASSWORD=change_this_password

# Connection Pool (optional)
# KLABIS_DB_POOL_MAX_SIZE=20
# KLABIS_DB_POOL_MIN_IDLE=10
# KLABIS_DB_CONNECTION_TIMEOUT=30000
# KLABIS_DB_IDLE_TIMEOUT=300000
# KLABIS_DB_MAX_LIFETIME=1800000

# ==============================================================================
# SMTP EMAIL CONFIGURATION
# ==============================================================================

KLABIS_SMTP_HOST=smtp.example.com
KLABIS_SMTP_PORT=587
KLABIS_SMTP_USERNAME=your-smtp-user
KLABIS_SMTP_PASSWORD=your-smtp-password

# ==============================================================================
# OAUTH2 & SECURITY
# ==============================================================================

KLABIS_OAUTH2_ISSUER=https://localhost:8443

# Bootstrap Admin (if not set, random password will be generated)
KLABIS_ADMIN_USERNAME=admin
KLABIS_ADMIN_PASSWORD=admin123

# OAuth2 Client (if not set, random secret will be generated)
KLABIS_OAUTH2_CLIENT_ID=klabis-web
KLABIS_OAUTH2_CLIENT_SECRET=secret
# KLABIS_OAUTH2_CLIENT_UUID=
# KLABIS_OAUTH2_CLIENT_REDIRECT_URIS=http://localhost:3000/auth/callback
# KLABIS_OAUTH2_POST_LOGOUT_REDIRECT_URI=https://wiki.zabiny.club
# KLABIS_OAUTH2_CLIENT_SCOPES=MEMBERS:CREATE,MEMBERS:READ,MEMBERS:UPDATE,MEMBERS:DELETE

# ==============================================================================
# FRONTEND CORS
# ==============================================================================

KLABIS_FRONTEND_ALLOWED_ORIGINS=http://localhost:3000
KLABIS_FRONTEND_ALLOW_CREDENTIALS=true

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================

KLABIS_CLUB_CODE=ZBM
KLABIS_BASE_URL=https://localhost:8443

# ==============================================================================
# NOTES
# ==============================================================================
#
# 1. SECURITY: Never commit .env files. Use strong passwords in production.
# 2. DEVELOPMENT: 'dev' profile uses H2 in-memory database (no DB setup needed).
# 3. PRODUCTION: Set all credentials explicitly, use 'prod' profile.
# 4. JASYPT: Keep encryption password backed up securely.

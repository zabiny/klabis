{
  "permissions": {
    "allow": [
      "mcp__plugin_playwright_playwright__browser_snapshot",
      "mcp__plugin_playwright_playwright__browser_wait_for",
      "mcp__plugin_playwright_playwright__browser_network_requests",
      "mcp__plugin_playwright_playwright__browser_console_messages",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__get_network_request",
      "mcp__jetbrains__get_file_text_by_path",
      "Bash(lsof:*)",
      "Bash(openspec status:*)",
      "Bash(openspec validate:*)",
      "Bash(openspec instructions:*)",
      "Bash(openspec list:*)",
      "Bash(./runLocalEnvironment.sh)",
      "Bash(./runLocalEnvironment.sh:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath // empty' | { read -r f; if echo \"$f\" | grep -qE 'frontend/.*\\.(ts|tsx|js|jsx)$'; then cd frontend && npx eslint --fix \"$f\" 2>/dev/null; fi; } || true",
            "statusMessage": "Running ESLint fix..."
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|Update",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q '\\.java$' && cd $(git rev-parse --show-toplevel) && ./gradlew compileJava -q 2>&1 | grep -E 'ERROR|WARN' | head -5 || true"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "sleep 1",
            "statusMessage": "Letting language server catch up to prevent stale diagnostics"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "sandbox": {
    "excludedCommands": [
      "./runLocalEnvironment.sh"
    ],
    "network": {
      "allowedDomains": [
        "repo.maven.apache.org",
        "repo1.maven.org",
        "plugins.gradle.org",
        "downloads.gradle.org",
        "services.gradle.org",
        "repo.spring.io",
        "gitlab.polach.cloud",
        "registry.npmjs.org"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "/home/davca/.gradle"
      ]
    }
  }
}
